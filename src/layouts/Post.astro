---
import Common from '../layouts/Common.astro'
import Md from "./Md.astro";

const { frontmatter } = Astro.props;
---
<Common>
<head>
    <meta charset="UTF-8" />
</head>

<div class="post-container">
  <h1 class="post-title">{frontmatter.title}</h1>
  <p class="post-description">{frontmatter.description}</p>
  <p class="post-date">{new Date(frontmatter.date).toLocaleDateString('ja-JP', { year: 'numeric', month: '2-digit', day: '2-digit' }).replace(/\//g, '-')}</p>
  <div class="tags">
    {frontmatter.tags.map((tag) => (
      <p class="tag"><a href={`/tags/${tag}`}>{tag}</a></p>
    ))}
  </div>


</div>
<div class="post">
  <Md>
      <slot />
  </Md>
</div>

</Common>

<style>
  .post-container {
    text-align: center;
  }

  .post-title {
    font-size: 2.5em;
    font-weight: bold;
    margin-top: 2em;
    border-left: None;
  }

  .post-description {
    font-size: 1.2em;
    color: #666;
    margin-top: -1em;
  }

  .post-date {
    color: #666;
  }

  .tags {
    margin-top: 1em;
    margin-bottom: 3em;
  }

  .tag {
    display: inline-block;
    margin-right: 0.5em;
  }

  .tag::before {
    content: "#";
  }

  .tag a {
    text-decoration: none;
    color: #59005c;
  }

  .tag a:hover {
    text-decoration: underline;
  }

</style>